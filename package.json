  },
  "bugs": {
    "url": "https://github.com/your-username/starcore/issues"
  },
  "homepage": "https://github.com/your-username/starcore",
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.3.0",
    "pino": "^9.7.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
