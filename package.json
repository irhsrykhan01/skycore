{
  "name": "@skyverse/starcore",
  "version": "0.1.0-beta.1",
  "description": "StarCore is a lightweight modular WhatsApp bot framework built on Baileys for SkyVerse.",
  "main": "index.js",
  "type": "module",
  "private": false,
  "scripts": {
    "start": "NODE_ENV=production node --expose-gc --max-old-space-size=256 index.js",
